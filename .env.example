# Google Sheets API Configuration
# You have two options to authenticate:

# Option 1: Use a JSON key file (recommended for local development)
# - Download the JSON key file from Google Cloud Console
# - Save it as: gen-lang-client-0312769039-f45a7c9ff94b.json
# - It's already in .gitignore, so it won't be committed

# Option 2: Use environment variables (recommended for production)
GOOGLE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----"

# Google Sheet ID (required)
GOOGLE_SHEET_ID="your-spreadsheet-id-here"

# NeonDB PostgreSQL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Kommo CRM
URL_KOMMO="your-domain.kommo.com"
SECRET_KEY_KOMMO="your-kommo-api-token"

# Vercel Cron Secret
CRON_SECRET="your-cron-secret-here"
